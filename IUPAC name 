    });
  };

  // --- IUPAC NAME DETERMINISTIC SOLVER ENGINE ---
  const solveIupacName = () => {
    let steps = [];
    let carbonChain = Array.from({ length: chainLength }, (_, i) => i + 1);

    steps.push({
      title: "Step 1: Identify Principal Functional Group & Parent Suffix",
      desc: `We analyze the molecule for high-priority functional groups. Our central group is: **${
        principalGroup === 'none' ? 'None (Alkane/Alkene/Alkyne only)' : principalGroup.replace('_', ' ').toUpperCase()
      }**.`,
      badge: principalGroup === 'none' ? 'Hydrocarbon' : 'Functional Group'
    });

    let primarySuffix = 'ane';
    if (saturation === 'alkene') primarySuffix = 'ene';
    if (saturation === 'alkyne') primarySuffix = 'yne';

    let principalSuffix = '';
    let suffixPriority = 10; 

    if (principalGroup === 'carboxylic_acid') {
      principalSuffix = 'oic acid';
      suffixPriority = 1;
    } else if (principalGroup === 'ester') {
      principalSuffix = 'oate';
      suffixPriority = 2;
    } else if (principalGroup === 'aldehyde') {
      principalSuffix = 'al';
      suffixPriority = 3;
    } else if (principalGroup === 'ketone') {
      principalSuffix = 'one';
      suffixPriority = 4;
    } else if (principalGroup === 'alcohol') {
      principalSuffix = 'ol';
      suffixPriority = 5;
    } else if (principalGroup === 'amine') {
      principalSuffix = 'amine';
      suffixPriority = 6;
    }

    let ltrScore = [];
    let rtlScore = [];

    let principalPosLtr = null;
    let principalPosRtl = null;

    if (principalGroup === 'carboxylic_acid' || principalGroup === 'aldehyde' || principalGroup === 'ester') {
      principalPosLtr = 1;
      principalPosRtl = 1;
    } else if (principalGroup === 'ketone') {
      principalPosLtr = 2;
      principalPosRtl = chainLength - 1;
    } else if (principalGroup === 'alcohol') {
      principalPosLtr = Math.min(3, chainLength);
      principalPosRtl = chainLength - principalPosLtr + 1;
    } else if (principalGroup === 'amine') {
      principalPosLtr = Math.min(4, chainLength);
      principalPosRtl = chainLength - principalPosLtr + 1;
    }

    if (principalPosLtr !== null) {
      ltrScore.push(principalPosLtr);
      rtlScore.push(principalPosRtl);
    }

    let unsatLtr = saturation !== 'alkane' ? unsaturatedPosition : null;
    let unsatRtl = saturation !== 'alkane' ? (chainLength - unsaturatedPosition) : null;
    if (unsatLtr !== null) {
      ltrScore.push(unsatLtr);
      rtlScore.push(unsatRtl);
    }

    let subPositionsLtr = Object.keys(substituents).map(Number).sort((a,b) => a-b);
    let subPositionsRtl = Object.keys(substituents).map(Number).map(pos => chainLength - pos + 1).sort((a,b) => a-b);

    if (subPositionsLtr.length > 0) {
      ltrScore.push(...subPositionsLtr);
      rtlScore.push(...subPositionsRtl);
    }

    let useLtr = true;
    let explanationDirection = "";

    for (let i = 0; i < Math.max(ltrScore.length, rtlScore.length); i++) {
      let lVal = ltrScore[i] || 999;
      let rVal = rtlScore[i] || 999;
      if (lVal < rVal) {
        useLtr = true;
        explanationDirection = `Left-to-Right gives lower numbering set: [${ltrScore.join(',')}] vs Right-to-Left: [${rtlScore.join(',')}].`;
        break;
      } else if (rVal < lVal) {
        useLtr = false;
        explanationDirection = `Right-to-Left gives lower numbering set: [${rtlScore.join(',')}] vs Left-to-Right: [${ltrScore.join(',')}].`;
        break;
      }
    }

    if (!explanationDirection) {
      useLtr = true;
      explanationDirection = "Both directions yield symmetrical coordinates. Defaulting to Left-to-Right.";
    }

    steps.push({
      title: "Step 2: Numbering the Parent Carbon Chain",
      desc: `We compare numbering direction to give priority groups the lowest possible coordinates (locants). Direction chosen: **${useLtr ? 'Left-to-Right' : 'Right-to-Left'}**. Reason: ${explanationDirection}`,
      badge: "Direction Decided"
    });

    let mappedSubstituents = [];
    Object.entries(substituents).forEach(([index, type]) => {
      let numIndex = Number(index);
      let finalIndex = useLtr ? numIndex : (chainLength - numIndex + 1);
      mappedSubstituents.push({ originalIdx: numIndex, locant: finalIndex, name: type });
    });

    let finalUnsatLocant = useLtr ? unsatLtr : unsatRtl;
    let finalPrincipalLocant = useLtr ? principalPosLtr : principalPosRtl;

    let groupedSubs = {};
    mappedSubstituents.forEach(sub => {
      if (!groupedSubs[sub.name]) {
        groupedSubs[sub.name] = [];
      }
      groupedSubs[sub.name].push(sub.locant);
    });

    Object.keys(groupedSubs).forEach(name => {
      groupedSubs[name].sort((a,b) => a-b);
    });

    let alphabetizedSubNames = Object.keys(groupedSubs).sort();
    let prefixParts = [];
    let substituentStepDetails = [];

    alphabetizedSubNames.forEach(name => {
      let locants = groupedSubs[name];
      let prefix = "";
      if (locants.length === 1) {
        prefix = `${locants[0]}-${name}`;
      } else if (locants.length === 2) {
        prefix = `${locants.join(',')}-di${name}`;
      } else if (locants.length === 3) {
        prefix = `${locants.join(',')}-tri${name}`;
      }
      prefixParts.push(prefix);
      substituentStepDetails.push(`${name.toUpperCase()} at carbon(s) ${locants.join(', ')}`);
    });

    steps.push({
      title: "Step 3: Identify & Organize Substituents",
      desc: substituentStepDetails.length > 0 
        ? `We found the following substituents, sorted alphabetically: ${substituentStepDetails.join(', ')}. Assembled prefix: **${prefixParts.join('-')}**`
        : "No alkyl or halogen substituents detected attached to the chain.",
      badge: "Substituents Sorted"
    });

    let rootWord = ALKANE_PREFIXES[chainLength] || 'alk';
    let assembledName = "";
    let endSuffix = "";

    if (principalGroup === 'none') {
      if (saturation === 'alkane') {
        endSuffix = "ane";
      } else {
        endSuffix = `-${finalUnsatLocant}-${primarySuffix}`;
      }
    } else {
      let satInfix = "an"; 
      if (saturation === 'alkene') satInfix = `-${finalUnsatLocant}-en`;
      if (saturation === 'alkyne') satInfix = `-${finalUnsatLocant}-yn`;

      if (principalGroup === 'carboxylic_acid') {
        endSuffix = `${satInfix}-oic acid`; 
      } else if (principalGroup === 'ester') {
        endSuffix = `${satInfix}-oate`; 
      } else if (principalGroup === 'aldehyde') {
        endSuffix = `${satInfix}-al`; 
      } else if (principalGroup === 'ketone') {
        endSuffix = `${satInfix}-${finalPrincipalLocant}-one`;
      } else if (principalGroup === 'alcohol') {
        endSuffix = `${satInfix}-${finalPrincipalLocant}-ol`;
      } else if (principalGroup === 'amine') {
        endSuffix = `${satInfix}-${finalPrincipalLocant}-amine`;
      }
    }

    let finalPrefix = prefixParts.length > 0 ? `${prefixParts.join('-')}-` : "";
    assembledName = `${finalPrefix}${rootWord}${endSuffix}`;

    assembledName = assembledName.replace(/-+/g, '-').replace(/-$/, '').toLowerCase();
    assembledName = assembledName.charAt(0).toUpperCase() + assembledName.slice(1);

    if (principalGroup === 'ester') {
      assembledName = "Methyl " + assembledName;
    }

    steps.push({
      title: "Step 4: Formulate Parent Stem and Assemble IUPAC Name",
      desc: `Combined Parent stem: **${rootWord.toUpperCase()}** + Saturation infix: **${saturation.toUpperCase()}** + Principal Group suffix. Final complete assembled name is: **${assembledName}**.`,
      badge: "Final Assembly"
    });

    setNamingOutput({ name: assembledName, steps });
  };

  // --- RENDERING 2D CHEMICAL STRUCTURE (SVG) ---
  const renderChemicalStructure2D = () => {
    let points = [];
    const width = 720;
    const height = 220;
    const startX = 50;
    const spacingX = (width - 100) / (chainLength - 1 || 1);

    for (let i = 0; i < chainLength; i++) {
      let x = startX + i * spacingX;
      let y = i % 2 === 0 ? 140 : 80;
      points.push({ x, y, id: i + 1 });
    }

    return (
      <svg className="w-full h-full bg-slate-900 rounded-xl overflow-hidden" viewBox={`0 0 ${width} ${height}`}>
        {/* Draw Bonds */}
        {points.map((pt, idx) => {
          if (idx === 0) return null;
          const prevPt = points[idx - 1];
          const isDouble = saturation === 'alkene' && idx === unsaturatedPosition;
          const isTriple = saturation === 'alkyne' && idx === unsaturatedPosition;

          if (isDouble) {
            return (
              <g key={`bond-${idx}`}>
                <line x1={prevPt.x} y1={prevPt.y - 3} x2={pt.x} y2={pt.y - 3} stroke="#3b82f6" strokeWidth="4" />
                <line x1={prevPt.x} y1={prevPt.y + 3} x2={pt.x} y2={pt.y + 3} stroke="#3b82f6" strokeWidth="4" />
                <text x={(prevPt.x + pt.x)/2} y={(prevPt.y + pt.y)/2 - 12} fill="#3b82f6" className="text-[10px] font-bold" textAnchor="middle">Double</text>
              </g>
            );
          } else if (isTriple) {
            return (
              <g key={`bond-${idx}`}>
                <line x1={prevPt.x} y1={prevPt.y - 5} x2={pt.x} y2={pt.y - 5} stroke="#8b5cf6" strokeWidth="3" />
                <line x1={prevPt.x} y1={prevPt.y} x2={pt.x} y2={pt.y} stroke="#8b5cf6" strokeWidth="3" />
                <line x1={prevPt.x} y1={prevPt.y + 5} x2={pt.x} y2={pt.y + 5} stroke="#8b5cf6" strokeWidth="3" />
                <text x={(prevPt.x + pt.x)/2} y={(prevPt.y + pt.y)/2 - 14} fill="#8b5cf6" className="text-[10px] font-bold" textAnchor="middle">Triple</text>
              </g>
            );
          } else {
            return (
              <line key={`bond-${idx}`} x1={prevPt.x} y1={prevPt.y} x2={pt.x} y2={pt.y} stroke="#94a3b8" strokeWidth="3" />
            );
          }
        })}

        {/* Draw Principal Functional Groups */}
        {points.map((pt) => {
          let hasGroup = false;
          let groupLabel = "";
          let groupColor = "";

          if (principalGroup === 'carboxylic_acid' && pt.id === 1) {
            hasGroup = true;
            groupLabel = "COOH";
            groupColor = "#ef4444";
          } else if (principalGroup === 'ester' && pt.id === 1) {
            hasGroup = true;
            groupLabel = "COOMe";
            groupColor = "#ec4899";
          } else if (principalGroup === 'aldehyde' && pt.id === 1) {
            hasGroup = true;
            groupLabel = "CHO";
            groupColor = "#f97316";
          } else if (principalGroup === 'ketone' && pt.id === 2) {
            hasGroup = true;
            groupLabel = "=O";
            groupColor = "#eab308";
          } else if (principalGroup === 'alcohol' && pt.id === Math.min(3, chainLength)) {
            hasGroup = true;
            groupLabel = "-OH";
            groupColor = "#10b981";
          } else if (principalGroup === 'amine' && pt.id === Math.min(4, chainLength)) {
            hasGroup = true;
            groupLabel = "-NH2";
            groupColor = "#06b6d4";
          }

          if (!hasGroup) return null;

          return (
            <g key={`p-group-${pt.id}`}>
              <line x1={pt.x} y1={pt.y} x2={pt.x} y2={pt.y > 100 ? pt.y + 35 : pt.y - 35} stroke={groupColor} strokeWidth="2.5" strokeDasharray="3,3" />
              <circle cx={pt.x} cy={pt.y > 100 ? pt.y + 35 : pt.y - 35} r="18" fill={groupColor} className="animate-pulse" />
              <text x={pt.x} y={pt.y > 100 ? pt.y + 39 : pt.y - 31} fill="#ffffff" className="text-[10px] font-black" textAnchor="middle">
                {groupLabel}
              </text>
            </g>
          );
        })}

        {/* Draw Substituents */}
        {Object.entries(substituents).map(([idxStr, type]) => {
          const idx = Number(idxStr);
          const pt = points[idx - 1];
          if (!pt) return null;

          const subConfig = SUBSTITUENTS.find(s => s.id === type);
          const color = subConfig ? subConfig.color : "#cbd5e1";
          const formula = subConfig ? subConfig.formula : "R";
          const dirY = pt.y > 100 ? -40 : 40;

          return (
            <g key={`sub-${idx}`}>
              <line x1={pt.x} y1={pt.y} x2={pt.x} y2={pt.y + dirY} stroke={color} strokeWidth="2.5" />
              <circle cx={pt.x} cy={pt.y + dirY} r="16" fill={color} />
              <text x={pt.x} y={pt.y + dirY + 4} fill="#ffffff" className="text-[10px] font-black" textAnchor="middle">
                {formula}
              </text>
            </g>
          );
        })}

        {/* Draw Carbon Atoms (Nodes) */}
        {points.map((pt) => {
          return (
            <g key={`node-${pt.id}`}>
              <circle cx={pt.x} cy={pt.y} r="14" fill="#1e293b" stroke="#38bdf8" strokeWidth="2" />
              <text x={pt.x} y={pt.y + 4} fill="#f8fafc" className="text-xs font-bold" textAnchor="middle">
                {`C${pt.id}`}
              </text>
            </g>
          );
        })}
      </svg>
    );
  };

  // --- QUIZ SUBMISSION HANDLER ---

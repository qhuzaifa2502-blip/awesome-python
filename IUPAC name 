// --- 3D MOLECULAR VIEWER COMPONENT ---
function MoleculeThreeDViewer({ chainLength, saturation, unsaturatedPosition, principalGroup, substituents }) {
  const containerRef = useRef(null);
  const [threeLoaded, setThreeLoaded] = useState(false);
  const [loadingError, setLoadingError] = useState(false);

  // Dynamically load Three.js from CDN
  useEffect(() => {
    if (window.THREE) {
      setThreeLoaded(true);
      return;
    }
    const script = document.createElement('script');
    script.src = "https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js";
    script.async = true;
    script.onload = () => setThreeLoaded(true);
    script.onerror = () => setLoadingError(true);
    document.head.appendChild(script);
  }, []);

  useEffect(() => {
    if (!threeLoaded || !containerRef.current) return;

    const THREE = window.THREE;
    const width = containerRef.current.clientWidth;
    const height = containerRef.current.clientHeight;

    // Create scene, camera, renderer
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x0f172a); // Slate-900

    const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 100);
    camera.position.set(0, 0, 12);

    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(width, height);
    renderer.setPixelRatio(window.devicePixelRatio);
    containerRef.current.innerHTML = '';
    containerRef.current.appendChild(renderer.domElement);

    // Add Lights
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);
    scene.add(ambientLight);

    const dirLight1 = new THREE.DirectionalLight(0xffffff, 0.8);
    dirLight1.position.set(5, 10, 7);
    scene.add(dirLight1);

    const dirLight2 = new THREE.DirectionalLight(0x38bdf8, 0.3); // Sky-blue ambient highlight
    dirLight2.position.set(-5, -5, -5);
    scene.add(dirLight2);

    // Master Pivot Group
    const masterGroup = new THREE.Group();
    scene.add(masterGroup);

    // Helper: Create Shiny Sphere
    const createSphere = (color, radius, x, y, z) => {
      const geom = new THREE.SphereGeometry(radius, 32, 32);
      const mat = new THREE.MeshPhongMaterial({
        color: color,
        shininess: 90,
        specular: 0x444444
      });
      const mesh = new THREE.Mesh(geom, mat);
      mesh.position.set(x, y, z);
      return mesh;
    };

    // Helper: Create Cylindrical Bond
    const createBond = (p1, p2, color = 0x94a3b8, radius = 0.1, offsetZ = 0, offsetY = 0) => {
      const pos1 = new THREE.Vector3(p1.x, p1.y, p1.z);
      const pos2 = new THREE.Vector3(p2.x, p2.y, p2.z);

      if (offsetZ !== 0 || offsetY !== 0) {
        const shift = new THREE.Vector3(0, offsetY, offsetZ);
        pos1.add(shift);
        pos2.add(shift);
      }

      const direction = new THREE.Vector3().subVectors(pos2, pos1);
      const length = direction.length();

      const geom = new THREE.CylinderGeometry(radius, radius, length, 16);
      const mat = new THREE.MeshPhongMaterial({ color: color, shininess: 80 });
      const mesh = new THREE.Mesh(geom, mat);

      const midpoint = new THREE.Vector3().addVectors(pos1, pos2).multiplyScalar(0.5);
      mesh.position.copy(midpoint);

      const upVec = new THREE.Vector3(0, 1, 0);
      direction.normalize();
      mesh.quaternion.setFromUnitVectors(upVec, direction);

      return mesh;
    };

    // Calculate dynamic 3D zigzag positions for Carbon Atoms
    const carbonPoints = [];
    const spacingX = 1.4;
    const offsetX = -((chainLength - 1) * spacingX) / 2;

    for (let i = 0; i < chainLength; i++) {
      const x = offsetX + i * spacingX;
      const y = i % 2 === 0 ? 0.7 : -0.7;
      carbonPoints.push({ x, y, z: 0, id: i + 1 });
    }

    // 1. Render bonds along the main chain
    for (let i = 0; i < chainLength - 1; i++) {
      const p1 = carbonPoints[i];
      const p2 = carbonPoints[i + 1];
      const isUnsat = saturation !== 'alkane' && (i + 1) === unsaturatedPosition;

      if (isUnsat) {
        if (saturation === 'alkene') {
          // Double Bond: 2 parallel cylinders
          masterGroup.add(createBond(p1, p2, 0x3b82f6, 0.08, 0.15, 0));
          masterGroup.add(createBond(p1, p2, 0x3b82f6, 0.08, -0.15, 0));
        } else if (saturation === 'alkyne') {
          // Triple Bond: 3 parallel cylinders
          masterGroup.add(createBond(p1, p2, 0x8b5cf6, 0.07, 0, 0));
          masterGroup.add(createBond(p1, p2, 0x8b5cf6, 0.07, 0.18, 0.1));
          masterGroup.add(createBond(p1, p2, 0x8b5cf6, 0.07, -0.18, -0.1));
        }
      } else {
        // Single Bond
        masterGroup.add(createBond(p1, p2, 0x94a3b8, 0.12, 0, 0));
      }
    }

    // 2. Render Principal Functional Groups (Ball & Stick representation)
    carbonPoints.forEach(pt => {
      let isSpecial = false;

      // Carboxylic Acid (-COOH) on C1
      if (principalGroup === 'carboxylic_acid' && pt.id === 1) {
        isSpecial = true;
        // Double bond to Oxygen
        const oxyDoublePos = { x: pt.x - 0.7, y: pt.y + 1.2, z: 0 };
        masterGroup.add(createBond(pt, oxyDoublePos, 0xef4444, 0.06, 0.1, 0));
        masterGroup.add(createBond(pt, oxyDoublePos, 0xef4444, 0.06, -0.1, 0));
        masterGroup.add(createSphere(0xef4444, 0.45, oxyDoublePos.x, oxyDoublePos.y, oxyDoublePos.z)); // Oxygen

        // Single bond to hydroxyl Oxygen
        const oxySinglePos = { x: pt.x - 0.7, y: pt.y - 1.0, z: 0.5 };
        masterGroup.add(createBond(pt, oxySinglePos, 0xef4444, 0.08, 0, 0));
        masterGroup.add(createSphere(0xef4444, 0.45, oxySinglePos.x, oxySinglePos.y, oxySinglePos.z)); // Oxygen

        // Hydroxyl Hydrogen
        const hydroPos = { x: oxySinglePos.x - 0.5, y: oxySinglePos.y - 0.5, z: 0.8 };
        masterGroup.add(createBond(oxySinglePos, hydroPos, 0xffffff, 0.05, 0, 0));
        masterGroup.add(createSphere(0xffffff, 0.25, hydroPos.x, hydroPos.y, hydroPos.z)); // Hydrogen
      }

      // Ester (-COOCH3) on C1
      else if (principalGroup === 'ester' && pt.id === 1) {
        isSpecial = true;
        // Double bond to Oxygen
        const oxyDoublePos = { x: pt.x - 0.7, y: pt.y + 1.2, z: 0 };
        masterGroup.add(createBond(pt, oxyDoublePos, 0xec4899, 0.06, 0.1, 0));
        masterGroup.add(createBond(pt, oxyDoublePos, 0xec4899, 0.06, -0.1, 0));
        masterGroup.add(createSphere(0xef4444, 0.45, oxyDoublePos.x, oxyDoublePos.y, oxyDoublePos.z)); // Oxygen

        // Single bond to bridging Oxygen
        const bridgeOxyPos = { x: pt.x - 0.7, y: pt.y - 1.0, z: 0.5 };
        masterGroup.add(createBond(pt, bridgeOxyPos, 0xec4899, 0.08, 0, 0));
        masterGroup.add(createSphere(0xef4444, 0.45, bridgeOxyPos.x, bridgeOxyPos.y, bridgeOxyPos.z)); // Oxygen

        // Methyl Carbon
        const methylCarbPos = { x: bridgeOxyPos.x - 1.0, y: bridgeOxyPos.y, z: 0.8 };
        masterGroup.add(createBond(bridgeOxyPos, methylCarbPos, 0x94a3b8, 0.1, 0, 0));
        masterGroup.add(createSphere(0x64748b, 0.5, methylCarbPos.x, methylCarbPos.y, methylCarbPos.z)); // Carbon
      }

      // Aldehyde (-CHO) on C1
      else if (principalGroup === 'aldehyde' && pt.id === 1) {
        isSpecial = true;
        // Double bond to Oxygen
        const oxyDoublePos = { x: pt.x - 0.7, y: pt.y + 1.2, z: 0 };
        masterGroup.add(createBond(pt, oxyDoublePos, 0xf97316, 0.06, 0.1, 0));
        masterGroup.add(createBond(pt, oxyDoublePos, 0xf97316, 0.06, -0.1, 0));
        masterGroup.add(createSphere(0xef4444, 0.45, oxyDoublePos.x, oxyDoublePos.y, oxyDoublePos.z)); // Oxygen

        // Single bond to Hydrogen
        const hydroPos = { x: pt.x - 0.8, y: pt.y - 0.8, z: 0.5 };
        masterGroup.add(createBond(pt, hydroPos, 0xffffff, 0.05, 0, 0));
        masterGroup.add(createSphere(0xffffff, 0.25, hydroPos.x, hydroPos.y, hydroPos.z)); // Hydrogen
      }

      // Ketone (=O) on C2
      else if (principalGroup === 'ketone' && pt.id === 2) {
        const doubleOxyPos = { x: pt.x, y: pt.y > 0 ? pt.y + 1.2 : pt.y - 1.2, z: 0 };
        masterGroup.add(createBond(pt, doubleOxyPos, 0xeab308, 0.06, 0, 0.1));
        masterGroup.add(createBond(pt, doubleOxyPos, 0xeab308, 0.06, 0, -0.1));
        masterGroup.add(createSphere(0xef4444, 0.45, doubleOxyPos.x, doubleOxyPos.y, doubleOxyPos.z)); // Oxygen
      }

      // Alcohol (-OH)
      else if (principalGroup === 'alcohol' && pt.id === Math.min(3, chainLength)) {
        const dir = pt.y > 0 ? 1 : -1;
        const oxyPos = { x: pt.x, y: pt.y + 1.2 * dir, z: 0.4 };
        masterGroup.add(createBond(pt, oxyPos, 0x10b981, 0.08, 0, 0));
        masterGroup.add(createSphere(0xef4444, 0.45, oxyPos.x, oxyPos.y, oxyPos.z)); // Oxygen

        const hydroPos = { x: oxyPos.x + 0.5, y: oxyPos.y + 0.4 * dir, z: 0.7 };
        masterGroup.add(createBond(oxyPos, hydroPos, 0xffffff, 0.05, 0, 0));
        masterGroup.add(createSphere(0xffffff, 0.25, hydroPos.x, hydroPos.y, hydroPos.z)); // Hydrogen
      }

      // Amine (-NH2)
      else if (principalGroup === 'amine' && pt.id === Math.min(4, chainLength)) {
        const dir = pt.y > 0 ? 1 : -1;
        const nitrogenPos = { x: pt.x, y: pt.y + 1.2 * dir, z: 0.4 };
        masterGroup.add(createBond(pt, nitrogenPos, 0x06b6d4, 0.08, 0, 0));
        masterGroup.add(createSphere(0x3b82f6, 0.45, nitrogenPos.x, nitrogenPos.y, nitrogenPos.z)); // Nitrogen (Blue)

        // Two Hydrogens
        const h1 = { x: nitrogenPos.x - 0.5, y: nitrogenPos.y + 0.5 * dir, z: 0.8 };
        const h2 = { x: nitrogenPos.x + 0.5, y: nitrogenPos.y + 0.5 * dir, z: 0.8 };
        masterGroup.add(createBond(nitrogenPos, h1, 0xffffff, 0.05, 0, 0));
        masterGroup.add(createBond(nitrogenPos, h2, 0xffffff, 0.05, 0, 0));
        masterGroup.add(createSphere(0xffffff, 0.25, h1.x, h1.y, h1.z));
        masterGroup.add(createSphere(0xffffff, 0.25, h2.x, h2.y, h2.z));
      }

      // Default central Carbon Sphere rendering
      masterGroup.add(createSphere(0x475569, 0.55, pt.x, pt.y, pt.z));
    });

    // 3. Render Substituents (Alkyls / Halogens)
    Object.entries(substituents).forEach(([idxStr, type]) => {
      const idx = Number(idxStr);
      const pt = carbonPoints[idx - 1];
      if (!pt) return;

      const subConfig = SUBSTITUENTS.find(s => s.id === type);
      const hexColor = subConfig ? parseInt(subConfig.color.replace('#', '0x')) : 0xcbd5e1;

      const dir = pt.y > 0 ? -1 : 1; // Project away from chain zigzag
      const subPos = { x: pt.x, y: pt.y + 1.3 * dir, z: 0 };

      if (type === 'methyl') {
        masterGroup.add(createBond(pt, subPos, hexColor, 0.08, 0, 0));
        masterGroup.add(createSphere(0x64748b, 0.5, subPos.x, subPos.y, subPos.z)); // Carbon
        // Render 3 tiny hydrogens surrounding the methyl group
        const h1 = { x: subPos.x - 0.4, y: subPos.y + 0.3 * dir, z: 0.4 };
        const h2 = { x: subPos.x + 0.4, y: subPos.y + 0.3 * dir, z: 0.4 };
        const h3 = { x: subPos.x, y: subPos.y + 0.5 * dir, z: -0.4 };
        masterGroup.add(createBond(subPos, h1, 0xffffff, 0.04));
        masterGroup.add(createBond(subPos, h2, 0xffffff, 0.04));
        masterGroup.add(createBond(subPos, h3, 0xffffff, 0.04));
        masterGroup.add(createSphere(0xffffff, 0.22, h1.x, h1.y, h1.z));
        masterGroup.add(createSphere(0xffffff, 0.22, h2.x, h2.y, h2.z));
        masterGroup.add(createSphere(0xffffff, 0.22, h3.x, h3.y, h3.z));
      } else if (type === 'ethyl') {
        // Multi-carbon branch (two interconnected slate spheres)
        const firstCarbon = subPos;
        const secondCarbon = { x: subPos.x - 0.8, y: subPos.y + 0.8 * dir, z: 0.3 };

        masterGroup.add(createBond(pt, firstCarbon, hexColor, 0.08));
        masterGroup.add(createSphere(0x64748b, 0.5, firstCarbon.x, firstCarbon.y, firstCarbon.z));

        masterGroup.add(createBond(firstCarbon, secondCarbon, hexColor, 0.08));
        masterGroup.add(createSphere(0x64748b, 0.5, secondCarbon.x, secondCarbon.y, secondCarbon.z));
      } else {
        // Halogen Atom Sphere (Cl, Br, F)
        masterGroup.add(createBond(pt, subPos, hexColor, 0.08, 0, 0));
        masterGroup.add(createSphere(hexColor, 0.48, subPos.x, subPos.y, subPos.z));
      }
    });

    // --- Interactive Rotation Logic (Mouse Drag & Touch Sweep) ---
    let isDragging = false;
    let previousMousePosition = { x: 0, y: 0 };

    const handleStart = (clientX, clientY) => {
      isDragging = true;
      previousMousePosition = { x: clientX, y: clientY };
    };

    const handleMove = (clientX, clientY) => {
      if (!isDragging) return;
      const deltaX = clientX - previousMousePosition.x;
      const deltaY = clientY - previousMousePosition.y;

      masterGroup.rotation.y += deltaX * 0.01;
      masterGroup.rotation.x += deltaY * 0.01;

      previousMousePosition = { x: clientX, y: clientY };
    };

    const handleEnd = () => {
      isDragging = false;
    };

    // Attach listeners directly to canvas
    const dom = renderer.domElement;
    dom.addEventListener('mousedown', (e) => handleStart(e.clientX, e.clientY));
    dom.addEventListener('mousemove', (e) => handleMove(e.clientX, e.clientY));
    window.addEventListener('mouseup', handleEnd);

    dom.addEventListener('touchstart', (e) => {
      if (e.touches.length === 1) {
        handleStart(e.touches[0].clientX, e.touches[0].clientY);
      }
    }, { passive: true });

    dom.addEventListener('touchmove', (e) => {
      if (e.touches.length === 1) {
        handleMove(e.touches[0].clientX, e.touches[0].clientY);
      }
    }, { passive: true });

    window.addEventListener('touchend', handleEnd);

    // Initial slow rotation
    masterGroup.rotation.y = 0.4;
    masterGroup.rotation.x = 0.25;

    // Animation loop
    let reqId;
    const animate = () => {
      reqId = requestAnimationFrame(animate);
      if (!isDragging) {
        masterGroup.rotation.y += 0.003; // Gentle idle spin
      }
      renderer.render(scene, camera);
    };
    animate();

    // Clean-up on unmount/state changes
    return () => {
      cancelAnimationFrame(reqId);
      window.removeEventListener('mouseup', handleEnd);
      window.removeEventListener('touchend', handleEnd);
      if (containerRef.current) {
        containerRef.current.innerHTML = '';
      }
    };
  }, [threeLoaded, chainLength, saturation, unsaturatedPosition, principalGroup, substituents]);

  if (loadingError) {
    return (
      <div className="w-full h-full flex items-center justify-center bg-slate-950 rounded-xl border border-red-500/20 p-6">
        <p className="text-xs text-red-400 font-bold">Failed to load the 3D graphics environment. Please check your network connection.</p>
      </div>
    );
  }

  return (
    <div className="w-full h-full relative overflow-hidden bg-slate-950 rounded-xl">
      {!threeLoaded && (
        <div className="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-slate-950 z-20">
          <div className="w-10 h-10 border-4 border-sky-500 border-t-transparent rounded-full animate-spin"></div>
          <span className="text-xs text-slate-400 font-bold tracking-wider">Compiling WebGL Scene...</span>
        </div>
      )}
      <div ref={containerRef} className="w-full h-full cursor-grab active:cursor-grabbing" />
      <div className="absolute bottom-3 right-3 bg-slate-900/80 backdrop-blur-sm border border-slate-800 rounded-lg px-3 py-1 text-[10px] text-slate-400 font-bold pointer-events-none select-none">
        Drag to Orbit Molecule
      </div>
    </div>
  );
}


                      <td className="p-3 font-mono">-CO-</td>
                      <td className="p-3 text-slate-400">oxo-</td>
                      <td className="p-3 font-semibold text-emerald-400">-one</td>
                    </tr>
                    <tr className="hover:bg-slate-850/50">
                      <td className="p-3 font-bold text-emerald-400">5</td>
                      <td className="p-3 text-white font-bold">Alcohol</td>
                      <td className="p-3 font-mono">-OH</td>
                      <td className="p-3 text-slate-400">hydroxy-</td>
                      <td className="p-3 font-semibold text-emerald-400">-ol</td>
                    </tr>
                    <tr className="hover:bg-slate-850/50">
                      <td className="p-3 font-bold text-cyan-400">6</td>
                      <td className="p-3 text-white font-bold">Amine</td>
                      <td className="p-3 font-mono">-NH2</td>
                      <td className="p-3 text-slate-400">amino-</td>
                      <td className="p-3 font-semibold text-cyan-400">-amine</td>
                    </tr>
                    <tr className="hover:bg-slate-850/50">
                      <td className="p-3 font-bold text-sky-400">7</td>
                      <td className="p-3 text-white font-bold">Alkene (Double)</td>
                      <td className="p-3 font-mono">-C=C-</td>
                      <td className="p-3 text-slate-400">alkenyl-</td>
                      <td className="p-3 font-semibold text-emerald-400">-ene</td>
                    </tr>
                    <tr className="hover:bg-slate-850/50">
                      <td className="p-3 font-bold text-violet-400">8</td>
                      <td className="p-3 text-white font-bold">Alkyne (Triple)</td>
                      <td className="p-3 font-mono">-C≡C-</td>
                      <td className="p-3 text-slate-400">alkynyl-</td>
                      <td className="p-3 font-semibold text-emerald-400">-yne</td>
                    </tr>
                    <tr className="hover:bg-slate-850/50">
                      <td className="p-3 font-bold text-slate-500">9</td>
                      <td className="p-3 text-white font-bold">Alkyl / Halogens</td>
                      <td className="p-3 font-mono">-R / -X</td>
                      <td className="p-3 text-slate-400">alkyl-, halo-</td>
                      <td className="p-3 text-slate-500">-ane (Base alkane)</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

          </div>
        )}

        {/* TAB 3: QUIZ MODE */}
        {activeTab === 'quiz' && (
          <div className="max-w-xl mx-auto bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-xl space-y-6">
            
            <div className="flex items-center justify-between border-b border-slate-850 pb-3">
              <div className="space-y-1">
                <span className="text-xs font-black uppercase text-slate-400 tracking-wider">Quiz Mode</span>
                <h2 className="text-lg font-black text-white">Nomenclature Self-Assessment</h2>
              </div>
              <span className="text-xs bg-sky-500/10 text-sky-400 font-bold px-3 py-1 rounded-full border border-sky-500/20">
                Score: {quizScore} / {QUIZ_QUESTIONS.length}
              </span>
            </div>

            {/* Current Question Block */}
            <div className="space-y-4">
              <div className="flex justify-between items-center text-xs text-slate-400 font-bold">
                <span>Question {currentQuizIndex + 1} of {QUIZ_QUESTIONS.length}</span>
                <span className={`px-2 py-0.5 rounded font-bold ${
                  QUIZ_QUESTIONS[currentQuizIndex].difficulty === 'Easy' ? 'bg-emerald-500/10 text-emerald-400' :
                  QUIZ_QUESTIONS[currentQuizIndex].difficulty === 'Medium' ? 'bg-yellow-500/10 text-yellow-400' : 'bg-red-500/10 text-red-400'
                }`}>
                  {QUIZ_QUESTIONS[currentQuizIndex].difficulty}
                </span>
              </div>

              <h3 className="text-sm md:text-base font-bold text-white leading-relaxed">
                {QUIZ_QUESTIONS[currentQuizIndex].question}
              </h3>

              {/* Options list */}
              <div className="space-y-2">
                {QUIZ_QUESTIONS[currentQuizIndex].options.map((option, idx) => {
                  let borderClass = "border-slate-800 hover:border-slate-700 bg-slate-950";
                  let bgTextClass = "text-slate-300";

                  if (selectedOption === idx) {
                    borderClass = "border-sky-500 bg-sky-500/5";
                    bgTextClass = "text-sky-400";
                  }

                  if (quizSubmitted) {
                    if (idx === QUIZ_QUESTIONS[currentQuizIndex].correct) {
                      borderClass = "border-emerald-500 bg-emerald-500/10";
                      bgTextClass = "text-emerald-400";
                    } else if (selectedOption === idx) {
                      borderClass = "border-red-500 bg-red-500/10";
                      bgTextClass = "text-red-400";
                    } else {
                      borderClass = "border-slate-800 opacity-50";
                    }
                  }

                  return (
                    <button
                      key={`opt-${idx}`}
                      onClick={() => handleQuizAnswer(idx)}
                      disabled={quizSubmitted}
                      className={`w-full text-left p-3.5 rounded-xl border text-xs font-bold transition-all duration-150 flex items-center justify-between ${borderClass}`}
                    >
                      <span className={bgTextClass}>{option}</span>
                      
                      {quizSubmitted && idx === QUIZ_QUESTIONS[currentQuizIndex].correct && (
                        <CheckCircle2 className="w-4 h-4 text-emerald-500 shrink-0" />
                      )}
                      {quizSubmitted && selectedOption === idx && idx !== QUIZ_QUESTIONS[currentQuizIndex].correct && (
                        <XCircle className="w-4 h-4 text-red-500 shrink-0" />
                      )}
                    </button>
                  );
                })}
              </div>
            </div>

            {/* Explanatory Panel on Submission */}
            {quizSubmitted && (
              <div className="bg-slate-950/60 border border-slate-800 rounded-xl p-4 space-y-2 animate-fade-in">
                <span className="text-[10px] font-black uppercase text-sky-400 tracking-wider flex items-center gap-1.5">
                  <Info className="w-3.5 h-3.5" /> Explanation
                </span>
                <p className="text-xs text-slate-400 leading-relaxed">
                  {QUIZ_QUESTIONS[currentQuizIndex].explanation}
                </p>
              </div>
            )}

            {/* Submit / Next Actions */}
            <div className="flex gap-3">
              {!quizSubmitted ? (
                <button
                  onClick={submitQuizAnswer}
                  disabled={selectedOption === null}
                  className="w-full bg-sky-500 hover:bg-sky-400 disabled:opacity-50 disabled:hover:bg-sky-500 text-slate-950 font-black py-3 px-4 rounded-xl text-xs transition-all duration-150 flex items-center justify-center gap-2 shadow-lg shadow-sky-500/20"
                >
                  Verify Answer
                  <ArrowRight className="w-4 h-4" />
                </button>
              ) : (
                <button
                  onClick={nextQuizQuestion}
                  className="w-full bg-slate-800 hover:bg-slate-700 text-white font-black py-3 px-4 rounded-xl text-xs transition-all duration-150 flex items-center justify-center gap-2"
                >
                  {currentQuizIndex < QUIZ_QUESTIONS.length - 1 ? 'Next Question' : 'Restart Quiz'}
                  <ArrowRight className="w-4 h-4" />
                </button>
              )}
            </div>

          </div>
        )}

      </main>

      {/* Footer */}
      <footer className="border-t border-slate-850 py-6 bg-slate-950/60 mt-12 text-center text-[10px] text-slate-500">
        <div className="max-w-7xl mx-auto px-6">
          <p>© 2026 IUPAC Nomenclature Masterclass Interactive Core. All Rights Reserved.</p>
        </div>
      </footer>
    </div>
  );
}


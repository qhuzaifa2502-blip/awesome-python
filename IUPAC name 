      </header>

      {/* Main Content Area */}
      <main className="flex-1 max-w-7xl w-full mx-auto p-4 md:p-6 grid grid-cols-1 gap-6">
        
        {/* TAB 1: BUILDER & RESOLVER */}
        {activeTab === 'builder' && (
          <div className="grid grid-cols-1 lg:grid-cols-12 gap-6">
            
            {/* Left side: Configuration Panel */}
            <section className="lg:col-span-5 bg-slate-900 border border-slate-800 rounded-2xl p-5 flex flex-col gap-6 shadow-xl shadow-slate-950/50">
              <div className="flex items-center justify-between border-b border-slate-800 pb-3">
                <h2 className="text-md font-extrabold flex items-center gap-2 text-sky-400">

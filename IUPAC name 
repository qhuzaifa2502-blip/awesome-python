                  <div className="text-sm font-black mt-1">Primary Infix</div>
                </div>
                <ChevronRight className="text-slate-600 hidden md:block" />
                <div className="bg-emerald-500/25 border border-emerald-500/40 p-3 rounded-xl w-full">
                  <div className="text-emerald-400 text-[10px] uppercase font-black tracking-widest">Principal Group</div>
                  <div className="text-sm font-black mt-1">Secondary Suffix</div>
                </div>
              </div>
            </div>

            {/* IUPAC Functional Group Priority Table */}
            <div className="space-y-4 border-t border-slate-800 pt-6">

            </div>
            <div>
              <h1 className="text-xl font-black tracking-tight text-white flex items-center gap-2">
                IUPAC Nomenclature Explorer
                <span className="text-xs bg-sky-500/15 text-sky-400 px-2 py-0.5 rounded-full font-bold">Interactive Tool v2.0 - 3D edition</span>
              </h1>
              <p className="text-xs text-slate-400">Interactive organic chemistry modeler with a real-time webGL 3D molecular sandbox</p>
            </div>
          </div>
          
          {/* Navigation Tabs */}
          <nav className="flex bg-slate-950 p-1 rounded-xl border border-slate-800">

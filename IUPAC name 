              <div className="border border-slate-850 rounded-xl overflow-hidden">
                <table className="w-full text-left text-xs border-collapse">
                  <thead>
                    <tr className="bg-slate-950 text-slate-400 border-b border-slate-850 font-black">
                      <th className="p-3">Priority</th>
                      <th className="p-3">Functional Class</th>
                      <th className="p-3">Formula</th>
                      <th className="p-3">Prefix (as substituent)</th>
                      <th className="p-3">Suffix (as principal)</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-slate-850 text-slate-300">
                    <tr className="hover:bg-slate-850/50">
                      <td className="p-3 font-bold text-red-400">1</td>
                      <td className="p-3 text-white font-bold">Carboxylic Acid</td>
                      <td className="p-3 font-mono">-COOH</td>
                      <td className="p-3 text-slate-400">carboxy-</td>
                      <td className="p-3 font-semibold text-emerald-400">-oic acid</td>
                    </tr>
                    <tr className="hover:bg-slate-850/50">
                      <td className="p-3 font-bold text-pink-500">2</td>
                      <td className="p-3 text-white font-bold">Ester (Methyl)</td>
                      <td className="p-3 font-mono">-COOCH3</td>
                      <td className="p-3 text-slate-400">alkoxycarbonyl-</td>
                      <td className="p-3 font-semibold text-pink-400">-oate</td>
                    </tr>
                    <tr className="hover:bg-slate-850/50">
                      <td className="p-3 font-bold text-orange-400">3</td>
                      <td className="p-3 text-white font-bold">Aldehyde</td>
                      <td className="p-3 font-mono">-CHO</td>
                      <td className="p-3 text-slate-400">formyl- / oxo-</td>
                      <td className="p-3 font-semibold text-emerald-400">-al</td>
                    </tr>
                    <tr className="hover:bg-slate-850/50">
                      <td className="p-3 font-bold text-yellow-400">4</td>

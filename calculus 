```react
import React, { useState, useEffect, useRef } from 'react';
import { 
  FlaskConical, 
  HelpCircle, 
  BookOpen, 
  ArrowRight, 
  CheckCircle2, 
  XCircle, 
  RotateCcw, 
  Info, 
  ChevronRight, 
  Activity, 
  TrendingUp, 
  Maximize2,
  Bookmark,
  ChevronUp,
  ChevronDown,
  Trash2,
  ZoomIn,
  ZoomOut
} from 'lucide-react';

// --- MATH PRESETS FOR SMOOTH USER ONBOARDING ---
const FUNCTION_PRESETS = [
  { id: 'poly', name: 'Polynomial (x³ - 3x)', formula: 'x^3 - 3*x', desc: 'Classic cubic with dual turning points' },
  { id: 'trig', name: 'Trigonometric (sin(x))', formula: 'sin(x)', desc: 'Smooth periodic sine wave' },
  { id: 'exp', name: 'Exponential (e^x)', formula: 'exp(x)', desc: 'Rapidly growing natural exponential curve' },
  { id: 'rational', name: 'Rational (1/x)', formula: '1/x', desc: 'Asymmetric hyperbola with a vertical asymptote' },
  { id: 'bell', name: 'Bell Curve (exp(-x²))', formula: 'exp(-x^2)', desc: 'Symmetrical Gaussian distribution' },
];

export default function App() {
  const [activeTab, setActiveTab] = useState('derivative'); // 'limit', 'derivative', 'integral'
  const [functionInput, setFunctionInput] = useState('x^3 - 3*x');
  const [errorMessage, setErrorMessage] = useState(null);

  // --- TAB-SPECIFIC STATES ---
  // Limit
  const [limitPoint, setLimitPoint] = useState('0');
  const [limitResult, setLimitResult] = useState(null);
  const [limitTable, setLimitTable] = useState({ left: [], right: [] });

  // Derivative
  const [derivPoint, setDerivPoint] = useState('1');
  const [derivOrder, setDerivOrder] = useState('1'); // '1' or '2'
  const [derivResult, setDerivResult] = useState(null);

  // Integral
  const [integralMin, setIntegralMin] = useState('-2');
  const [integralMax, setIntegralMax] = useState('2');
  const [intervals, setIntervals] = useState(10); // Riemann subintervals N
  const [riemannMethod, setRiemannMethod] = useState('midpoint'); // 'left', 'right', 'midpoint', 'trapezoid'
  const [integralResult, setIntegralResult] = useState(null);

  // Graph Window Range Configuration
  const [zoomLevel, setZoomLevel] = useState(1);
  const [history, setHistory] = useState([]);
  const [calculationSteps, setCalculationSteps] = useState([]);

  // Trigger recalculation on state adjustments
  useEffect(() => {
    recalculateCalculus();
  }, [activeTab, functionInput, limitPoint, derivPoint, derivOrder, integralMin, integralMax, intervals, riemannMethod, zoomLevel]);

  // --- CORE SAFE MATH PARSING UTILITY ---
  const evaluateFunction = (expr, xVal) => {
    try {
      // Basic validation to protect runtime environment
      if (/[a-df-gi-jkm-oqrt-wyz]/i.test(expr.replace(/sin|cos|tan|exp|ln|pi|x/gi, ''))) {
        throw new Error("Invalid variable or algebraic function.");
      }

      let sanitized = expr.toLowerCase();
      sanitized = sanitized.replace(/sin/g, 'Math.sin');
      sanitized = sanitized.replace(/cos/g, 'Math.cos');
      sanitized = sanitized.replace(/tan/g, 'Math.tan');
      sanitized = sanitized.replace(/ln/g, 'Math.log');
      sanitized = sanitized.replace(/exp/g, 'Math.exp');
      sanitized = sanitized.replace(/pi/g, `(${Math.PI})`);
      sanitized = sanitized.replace(/e/g, `(${Math.E})`);
      sanitized = sanitized.replace(/\^/g, '**');
      
      // Implicit multiplication handling (e.g., 2x -> 2*x, 3Math.sin -> 3*Math.sin)
      sanitized = sanitized.replace(/(\d+)(Math\.|x)/g, '$1*$2');
      sanitized = sanitized.replace(/(\d+)\s*\(/g, '$1*(');

      // Perform local algebraic substitution for x
      const xEvaluator = sanitized.replace(/\bx\b/g, `(${xVal})`);
      
      // Safe dynamic function evaluation in isolated sandbox
      const calculatedVal = new Function(`return ${xEvaluator}`)();
      if (isNaN(calculatedVal) || !isFinite(calculatedVal)) return NaN;
      return calculatedVal;
    } catch (err) {
      return NaN;
    }
  };

  // --- CALCULATE CHOSEN MATHEMATICAL CONCEPT ---
  const recalculateCalculus = () => {
    setErrorMessage(null);
    setCalculationSteps([]);

    // Check basic preset evaluation viability
    const testVal = evaluateFunction(functionInput, 1);
    if (isNaN(testVal)) {
      setErrorMessage("Formula expression is invalid. Ensure operators are written clearly (e.g., use '*' for multiplication: '3*x' instead of '3x').");
      return;
    }

    if (activeTab === 'limit') {
      calculateLimit();
    } else if (activeTab === 'derivative') {
      calculateDerivative();
    } else if (activeTab === 'integral') {
      calculateIntegral();
    }
  };

  // --- LIMIT CALCULATION ENGINE ---
  const calculateLimit = () => {
    const target = parseFloat(limitPoint);
    if (isNaN(target)) {
      setErrorMessage("Enter a valid numerical value for x approaching a.");
      return;
    }

    const deltas = [0.1, 0.01, 0.001, 0.0001];
    const leftApproximations = [];
    const rightApproximations = [];

    deltas.forEach(delta => {
      const leftX = target - delta;
      const rightX = target + delta;
      leftApproximations.push({ x: parseFloat(leftX.toFixed(5)), y: evaluateFunction(functionInput, leftX) });
      rightApproximations.push({ x: parseFloat(rightX.toFixed(5)), y: evaluateFunction(functionInput, rightX) });
    });

    setLimitTable({ left: leftApproximations, right: rightApproximations });

    // Deduce functional limit values
    const closestLeftY = leftApproximations[3].y;
    const closestRightY = rightApproximations[3].y;

    if (isNaN(closestLeftY) && isNaN(closestRightY)) {
      setLimitResult("Undefined");
      return;
    }

    // Check if limits converge
    const isConverging = Math.abs(closestLeftY - closestRightY) < 0.05 || (isNaN(closestLeftY) === isNaN(closestRightY));
    
    if (isConverging) {
      const finalLimitVal = isNaN(closestLeftY) ? closestRightY : closestLeftY;
      setLimitResult(finalLimitVal.toFixed(5));
      
      setCalculationSteps([
        {
          title: "Approaching from Left-hand Side (x → a⁻)",
          desc: `As we evaluate points progressively closer to ${target} from smaller numbers (${target - 0.1}, ${target - 0.01}...), the output f(x) converges to **${closestLeftY.toFixed(5)}**.`
        },
        {
          title: "Approaching from Right-hand Side (x → a⁺)",
          desc: `As we evaluate points progressively closer to ${target} from larger numbers (${target + 0.1}, ${target + 0.01}...), the output f(x) converges to **${closestRightY.toFixed(5)}**.`
        },
        {
          title: "Deduce Convergence Criteria",
          desc: `Since both Left-hand limit (${closestLeftY.toFixed(5)}) and Right-hand limit (${closestRightY.toFixed(5)}) converge closely to the same numerical destination, the limit exists and equals **${finalLimitVal.toFixed(5)}**.`
        }
      ]);
    } else {
      setLimitResult("Does Not Exist (Diverges)");
      setCalculationSteps([
        {
          title: "Identify Divergent Behaviors",
          desc: `The Left-hand limit approaches **${closestLeftY ? closestLeftY.toFixed(5) : 'Undefined'}**, while the Right-hand limit approaches **${closestRightY ? closestRightY.toFixed(5) : 'Undefined'}**. Because they do not match, the system has a discontinuity at x = ${target}.`
        }
      ]);
    }
  };

  // --- DERIVATIVE CALCULATION ENGINE ---
  const calculateDerivative = () => {
    const pt = parseFloat(derivPoint);
    if (isNaN(pt)) {
      setErrorMessage("Enter a valid coordinate for x₀.");
      return;
    }

    const h = 0.0001; // Step interval size for central difference approximation
    
    if (derivOrder === '1') {
      // First derivative approximation using Central Difference
      const f_plus = evaluateFunction(functionInput, pt + h);
      const f_minus = evaluateFunction(functionInput, pt - h);
      
      if (isNaN(f_plus) || isNaN(f_minus)) {
        setErrorMessage("Function is non-differentiable at the selected point.");
        return;
      }

      const derivVal = (f_plus - f_minus) / (2 * h);
      setDerivResult(derivVal.toFixed(5));

      setCalculationSteps([
        {
          title: "Definition of Instantaneous Rate of Change",
          desc: `The derivative f'(x₀) measures the instantaneous slope of the function curve at x₀. It represents the limit of the secant line as the interval step size h approaches 0:\n\n$$f'(x) = \\lim_{h \\to 0} \\frac{f(x+h) - f(x-h)}{2h}$$`
        },
        {
          title: "Apply Central Difference Method",
          desc: `Using a high-precision symmetric interval (h = ${h}):\n\n$$f'(${pt}) \\approx \\frac{f(${pt + h}) - f(${pt - h})}{2 \\cdot ${h}}$$`
        },
        {
          title: "Evaluate Central Values",
          desc: `$$f(${pt + h}) = ${f_plus.toFixed(6)}$$\n\n$$f(${pt - h}) = ${f_minus.toFixed(6)}$$`
        },
        {
          title: "Deduce Tangent Slope",
          desc: `$$f'(${pt}) \\approx \\frac{${(f_plus - f_minus).toFixed(6)}}{0.0002} = ${derivVal.toFixed(5)}$$\n\nHence, the rate of change at x₀ is **${derivVal.toFixed(5)}**.`
        }
      ]);

    } else {
      // Second derivative numerical approximation
      const f_center = evaluateFunction(functionInput, pt);
      const f_plus = evaluateFunction(functionInput, pt + h);
      const f_minus = evaluateFunction(functionInput, pt - h);

      if (isNaN(f_plus) || isNaN(f_minus) || isNaN(f_center)) {
        setErrorMessage("Second derivative calculation failed. Check function continuity.");
        return;
      }

      const secondDerivVal = (f_plus - 2 * f_center + f_minus) / (h * h);
      setDerivResult(secondDerivVal.toFixed(5));

      setCalculationSteps([
        {
          title: "Definition of Concavity",
          desc: `The second derivative f''(x) measures concavity (the rate of change of the slope). It is calculated numerically using the second-order central difference:`
        },
        {
          title: "Symmetric Computation",
          desc: `$$f''(${pt}) \\approx \\frac{f(${pt + h}) - 2f(${pt}) + f(${pt - h})}{h^2}$$`
        },
        {
          title: "Evaluate Coordinate Heights",
          desc: `$$f(${pt + h}) = ${f_plus.toFixed(6)}$$\n\n$$f(${pt}) = ${f_center.toFixed(6)}$$\n\n$$f(${pt - h}) = ${f_minus.toFixed(6)}$$`
        },
        {
          title: "Deduce Second Derivative Concavity",
          desc: `$$f''(${pt}) \\approx ${secondDerivVal.toFixed(5)}$$\n\nAn output of **${secondDerivVal.toFixed(5)}** means the curve is **${secondDerivVal > 0 ? 'Concave Up (∪)' : 'Concave Down (∩)'}** at x = ${pt}.`
        }
      ]);
    }
  };

  // --- DEFINITE INTEGRAL CALCULATOR ENGINE ---
  const calculateIntegral = () => {
    const a = parseFloat(integralMin);
    const b = parseFloat(integralMax);
    const N = parseInt(intervals);

    if (isNaN(a) || isNaN(b)) {
      setErrorMessage("Please verify definite integral boundaries (a & b) are valid real numbers.");
      return;
    }
    if (a >= b) {
      setErrorMessage("The lower bound (a) must be less than the upper bound (b).");
      return;
    }
    if (isNaN(N) || N < 2 || N > 150) {
      setErrorMessage("Interval subdivisions (N) must be set between 2 and 150.");
      return;
    }

    const dx = (b - a) / N;
    let sum = 0;

    for (let i = 0; i < N; i++) {
      let xEval = a;
      if (riemannMethod === 'left') {
        xEval = a + i * dx;
      } else if (riemannMethod === 'right') {
        xEval = a + (i + 1) * dx;
      } else if (riemannMethod === 'midpoint') {
        xEval = a + (i + 0.5) * dx;
      } else if (riemannMethod === 'trapezoid') {
        const hLeft = evaluateFunction(functionInput, a + i * dx);
        const hRight = evaluateFunction(functionInput, a + (i + 1) * dx);
        sum += ((hLeft + hRight) / 2) * dx;
        continue;
      }
      const height = evaluateFunction(functionInput, xEval);
      if (!isNaN(height)) {
        sum += height * dx;
      }
    }

    setIntegralResult(sum.toFixed(5));

    setCalculationSteps([
      {
        title: "Deduce Subinterval Width (Δx)",
        desc: `The total width from a = ${a} to b = ${b} is divided into N = ${N} equal parts:\n\n$$\\Delta x = \\frac{b - a}{N} = \\frac{${b} - ${a}}{${N}} = ${dx.toFixed(4)}$$`
      },
      {
        title: "Approximation Rule Setup",
        desc: `We are using the **${riemannMethod.toUpperCase()}** approximation rule to measure the height of each rectangular subinterval.`
      },
      {
        title: "Total Area Summation Result",
        desc: `By summing up the calculated area blocks under the function curve:\n\n$$\\int_{${a}}^{${b}} f(x) \\,dx \\approx \\sum_{i=1}^{n} f(x_i) \\Delta x \\approx **${sum.toFixed(5)}**$$`
      }
    ]);
  };

  // --- SAVE TO EXERCISES LOG ---
  const handleSaveToHistory = () => {
    if (errorMessage) return;
    const historyItem = {
      id: Date.now(),
      tab: activeTab,
      formula: functionInput,
      result: activeTab === 'limit' ? limitResult : activeTab === 'derivative' ? derivResult : integralResult,
      details: activeTab === 'limit' ? `As x → ${limitPoint}` : activeTab === 'derivative' ? `f'(${derivPoint})` : `∫ from ${integralMin} to ${integralMax}`,
      timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
    };
    setHistory(prev => [historyItem, ...prev].slice(0, 10));
  };

  // --- SVG PLOTTER DRAWING ENGINE ---
  const renderVisualGraph = () => {
    const width = 650;
    const height = 300;
    const padding = 40;

    // View boundaries
    const xMin = -6 * zoomLevel;
    const xMax = 6 * zoomLevel;
    const yMin = -6 * zoomLevel;
    const yMax = 6 * zoomLevel;

    const getXPixel = (xVal) => {
      return padding + ((xVal - xMin) / (xMax - xMin)) * (width - 2 * padding);
    };

    const getYPixel = (yVal) => {
      return height - padding - ((yVal - yMin) / (yMax - yMin)) * (height - 2 * padding);
    };

    // 1. Generate core function path
    let points = [];
    const stepX = (xMax - xMin) / 180;
    for (let x = xMin; x <= xMax; x += stepX) {
      const y = evaluateFunction(functionInput, x);
      if (!isNaN(y) && isFinite(y)) {
        const px = getXPixel(x);
        const py = getYPixel(y);
        if (py >= 5 && py <= height - 5) {
          points.push(`${px},${py}`);
        }
      }
    }
    const pathD = points.length > 0 ? `M ${points.join(' L ')}` : '';

    // 2. Generate Riemann blocks shading for Definite Integrals
    const riemannBlocks = [];
    if (activeTab === 'integral' && !errorMessage) {
      const a = parseFloat(integralMin);
      const b = parseFloat(integralMax);
      const N = parseInt(intervals);
      if (!isNaN(a) && !isNaN(b) && a < b && N >= 2) {
        const dx = (b - a) / N;
        for (let i = 0; i < N; i++) {
          const xLeft = a + i * dx;
          const xRight = a + (i + 1) * dx;
          let xEval = xLeft;
          
          if (riemannMethod === 'right') xEval = xRight;
          else if (riemannMethod === 'midpoint') xEval = xLeft + 0.5 * dx;

          const heightVal = evaluateFunction(functionInput, xEval);
          if (!isNaN(heightVal)) {
            const pxLeft = getXPixel(xLeft);
            const pxRight = getXPixel(xRight);
            const pyBase = getYPixel(0);
            const pyHeight = getYPixel(heightVal);

            if (riemannMethod === 'trapezoid') {
              const hL = evaluateFunction(functionInput, xLeft);
              const hR = evaluateFunction(functionInput, xRight);
              const pyHL = getYPixel(hL);
              const pyHR = getYPixel(hR);
              riemannBlocks.push(
                <polygon
                  key={`riemann-${i}`}
                  points={`${pxLeft},${pyBase} ${pxLeft},${pyHL} ${pxRight},${pyHR} ${pxRight},${pyBase}`}
                  fill="rgba(56, 189, 248, 0.15)"
                  stroke="#38bdf8"
                  strokeWidth="1"
                />
              );
            } else {
              // Draw rectangular Riemann partition block
              riemannBlocks.push(
                <rect
                  key={`riemann-${i}`}
                  x={pxLeft}
                  y={heightVal >= 0 ? pyHeight : pyBase}
                  width={pxRight - pxLeft}
                  height={Math.abs(pyBase - pyHeight)}
                  fill="rgba(139, 92, 246, 0.15)"
                  stroke="#8b5cf6"
                  strokeWidth="1"
                />
              );
            }
          }
        }
      }
    }

    // 3. Generate Tangent line for derivatives
    let tangentLinePath = null;
    let targetPointDot = null;
    if (activeTab === 'derivative' && derivResult !== null && !errorMessage) {
      const x0 = parseFloat(derivPoint);
      const y0 = evaluateFunction(functionInput, x0);
      const slope = parseFloat(derivResult);

      if (!isNaN(y0) && !isNaN(slope)) {
        // Equation of tangent: y - y0 = m*(x - x0) -> y = slope*(x - x0) + y0
        const xStart = xMin;
        const yStart = slope * (xStart - x0) + y0;
        const xEnd = xMax;
        const yEnd = slope * (xEnd - x0) + y0;

        tangentLinePath = (
          <line
            x1={getXPixel(xStart)}
            y1={getYPixel(yStart)}
            x2={getXPixel(xEnd)}
            y2={getYPixel(yEnd)}
            stroke="#f59e0b"
            strokeWidth="2"
            strokeDasharray="4,4"
          />
        );

        targetPointDot = (
          <g>
            <circle cx={getXPixel(x0)} cy={getYPixel(y0)} r="7" fill="rgba(245, 158, 11, 0.3)" className="animate-ping" />
            <circle cx={getXPixel(x0)} cy={getYPixel(y0)} r="4.5" fill="#f59e0b" stroke="#0f172a" strokeWidth="1" />
          </g>
        );
      }
    }

    // 4. Generate limit convergence visual dots
    let limitConvergenceMarks = null;
    if (activeTab === 'limit' && !errorMessage) {
      const a = parseFloat(limitPoint);
      const limitY = parseFloat(limitResult);
      if (!isNaN(a) && !isNaN(limitY)) {
        limitConvergenceMarks = (
          <g>
            {/* Horizontal indicator */}
            <line x1={padding} y1={getYPixel(limitY)} x2={getXPixel(a)} y2={getYPixel(limitY)} stroke="#f43f5e" strokeWidth="1" strokeDasharray="3,3" />
            {/* Vertical indicator */}
            <line x1={getXPixel(a)} y1={getYPixel(0)} x2={getXPixel(a)} y2={getYPixel(limitY)} stroke="#f43f5e" strokeWidth="1" strokeDasharray="3,3" />
            <circle cx={getXPixel(a)} cy={getYPixel(limitY)} r="5" fill="#f43f5e" stroke="#0f172a" strokeWidth="1" />
          </g>
        );
      }
    }

    return (
      <svg className="w-full h-full bg-slate-950 rounded-2xl border border-slate-800" viewBox={`0 0 ${width} ${height}`}>
        {/* Render Gridlines and Origin Coordinates */}
        <line x1={padding} y1={getYPixel(0)} x2={width - padding} y2={getYPixel(0)} stroke="#1e293b" strokeWidth="2" /> {/* X-Axis */}
        <line x1={getXPixel(0)} y1={padding} x2={getXPixel(0)} y2={height - padding} stroke="#1e293b" strokeWidth="2" /> {/* Y-Axis */}

        {/* Ticks & Labels along Axes */}
        <text x={width - padding + 5} y={getYPixel(0) + 4} fill="#475569" className="text-[10px] font-bold">x</text>
        <text x={getXPixel(0) - 12} y={padding - 5} fill="#475569" className="text-[10px] font-bold">y</text>

        {/* Render Riemann Partition Blocks (under the curve) */}
        {riemannBlocks}

        {/* Render primary Mathematical function path */}
        {pathD && (
          <path 
            d={pathD} 
            fill="none" 
            stroke="#10b981" 
            strokeWidth="3" 
            className="transition-all duration-300" 
          />
        )}

        {/* Render tangent slopes */}
        {tangentLinePath}
        {targetPointDot}

        {/* Render limit bounds approaching target points */}
        {limitConvergenceMarks}
      </svg>
    );
  };

  return (
    <div className="min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans selection:bg-emerald-500 selection:text-white">
      {/* Header Banner */}
      <header className="border-b border-slate-900 bg-slate-900/80 backdrop-blur-md sticky top-0 z-50 px-6 py-4">
        <div className="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
          <div className="flex items-center gap-3">
            <div className="bg-emerald-500 p-2.5 rounded-xl text-slate-950 shadow-lg shadow-emerald-500/20">
              <FlaskConical className="w-6 h-6 stroke-[2.5]" />
            </div>
            <div>
              <h1 className="text-xl font-black tracking-tight text-white flex items-center gap-2">
                Visual Calculus Playground
                <span className="text-xs bg-emerald-500/15 text-emerald-400 px-2.5 py-0.5 rounded-full font-bold">Interactive Tool</span>
              </h1>
              <p className="text-xs text-slate-400">Estimate limits, derivatives, and definite integration bounds instantly with high-fidelity visual partitions</p>
            </div>
          </div>
          
          {/* Quick tab controls */}
          <nav className="flex bg-slate-950 p-1 rounded-xl border border-slate-900">
            <button 
              onClick={() => setActiveTab('limit')}
              className={`flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-bold transition-all duration-200 ${activeTab === 'limit' ? 'bg-emerald-500 text-slate-950 shadow-md' : 'text-slate-400 hover:text-white'}`}
            >
              <Activity className="w-3.5 h-3.5" />
              Limits Solver
            </button>
            <button 
              onClick={() => setActiveTab('derivative')}
              className={`flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-bold transition-all duration-200 ${activeTab === 'derivative' ? 'bg-emerald-500 text-slate-950 shadow-md' : 'text-slate-400 hover:text-white'}`}
            >
              <TrendingUp className="w-3.5 h-3.5" />
              Derivative Explorer
            </button>
            <button 
              onClick={() => setActiveTab('integral')}
              className={`flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-bold transition-all duration-200 ${activeTab === 'integral' ? 'bg-emerald-500 text-slate-950 shadow-md' : 'text-slate-400 hover:text-white'}`}
            >
              <BookOpen className="w-3.5 h-3.5" />
              Riemann Definite Integral
            </button>
          </nav>
        </div>
      </header>

      {/* Main Workspace Frame */}
      <main className="flex-1 max-w-7xl w-full mx-auto p-4 md:p-6 grid grid-cols-1 lg:grid-cols-12 gap-6">
        
        {/* Left Side Column: Configuration parameters (lg:col-span-5) */}
        <section className="lg:col-span-5 bg-slate-900 border border-slate-800 rounded-2xl p-5 flex flex-col gap-6 shadow-xl">
          
          <div className="space-y-4">
            <div className="flex items-center justify-between border-b border-slate-800 pb-2">
              <h2 className="text-sm font-extrabold flex items-center gap-2 text-emerald-400">
                <span className="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                Define Function f(x)
              </h2>
            </div>

            {/* Core input formula field */}
            <div className="space-y-2">
              <input
                type="text"
                value={functionInput}
                onChange={(e) => setFunctionInput(e.target.value)}
                placeholder="e.g., x^3 - 3*x"
                className="w-full bg-slate-950 border border-slate-800 rounded-xl py-3 px-4 text-sm font-mono text-emerald-400 outline-none focus:border-emerald-500"
              />
              <p className="text-[10px] text-slate-500">Supported keywords: <code className="text-slate-400">sin(x)</code>, <code className="text-slate-400">cos(x)</code>, <code className="text-slate-400">exp(x)</code>, <code className="text-slate-400">ln(x)</code>, <code className="text-slate-400">^</code>.</p>
            </div>

            {/* Presets list */}
            <div className="space-y-2">
              <span className="text-[10px] font-black uppercase text-slate-400 tracking-wider">Quick Presets</span>
              <div className="grid grid-cols-2 gap-2">
                {FUNCTION_PRESETS.map((p) => (
                  <button
                    key={p.id}
                    onClick={() => setFunctionInput(p.formula)}
                    className="py-1.5 px-2.5 bg-slate-950 border border-slate-800 hover:bg-slate-850 rounded-xl text-left text-xs transition-all"
                  >
                    <div className="font-bold text-slate-200">{p.name}</div>
                    <div className="text-[9px] text-slate-500 truncate">{p.desc}</div>
                  </button>
                ))}
              </div>
            </div>
          </div>

          {/* CALCULATOR PARAMETERS ACCORDING TO ACTIVE TAB */}
          <div className="space-y-4 border-t border-slate-800 pt-4">
            <h3 className="text-xs font-black uppercase text-slate-400 tracking-wider">Concept-specific variables</h3>

            {/* 1. LIMIT INTERACTIVE INPUTS */}
            {activeTab === 'limit' && (
              <div className="space-y-3">
                <div className="flex justify-between items-center text-xs">
                  <span className="text-slate-400 font-bold">As x approaches point (a):</span>
                </div>
                <input 
                  type="number" 
                  step="any"
                  value={limitPoint} 
                  onChange={(e) => setLimitPoint(e.target.value)}
                  className="w-full bg-slate-950 border border-slate-800 rounded-lg py-2 px-3 text-xs font-mono text-slate-200"
                />
              </div>
            )}

            {/* 2. DERIVATIVE INTERACTIVE INPUTS */}
            {activeTab === 'derivative' && (
              <div className="space-y-4">
                <div className="space-y-2">
                  <span className="text-[10px] font-black uppercase text-slate-400 tracking-wider block">Derivative Order</span>
                  <div className="grid grid-cols-2 gap-2">
                    <button
                      onClick={() => setDerivOrder('1')}
                      className={`py-2 px-3 rounded-xl border text-xs font-bold transition-all ${
                        derivOrder === '1' ? 'bg-emerald-500/15 border-emerald-500 text-emerald-400' : 'bg-slate-950 border-slate-800 text-slate-400'
                      }`}
                    >
                      1st Derivative (f')
                    </button>
                    <button
                      onClick={() => setDerivOrder('2')}
                      className={`py-2 px-3 rounded-xl border text-xs font-bold transition-all ${
                        derivOrder === '2' ? 'bg-emerald-500/15 border-emerald-500 text-emerald-400' : 'bg-slate-950 border-slate-800 text-slate-400'
                      }`}
                    >
                      2nd Derivative (f'')
                    </button>
                  </div>
                </div>

                <div className="space-y-2">
                  <span className="text-[10px] font-black uppercase text-slate-400 tracking-wider block">Evaluate point at x₀</span>
                  <input 
                    type="number" 
                    step="any"
                    value={derivPoint} 
                    onChange={(e) => setDerivPoint(e.target.value)}
                    className="w-full bg-slate-950 border border-slate-800 rounded-lg py-2 px-3 text-xs font-mono text-slate-200"
                  />
                </div>
              </div>
            )}

            {/* 3. INTEGRAL INTERACTIVE INPUTS */}
            {activeTab === 'integral' && (
              <div className="space-y-4">
                <div className="grid grid-cols-2 gap-3">
                  <div className="space-y-1">
                    <span className="text-[10px] font-black uppercase text-slate-400 tracking-wider block">Lower Limit (a)</span>
                    <input 
                      type="number" 
                      step="any"
                      value={integralMin} 
                      onChange={(e) => setIntegralMin(e.target.value)}
                      className="w-full bg-slate-950 border border-slate-800 rounded-lg py-2 px-3 text-xs font-mono text-slate-200"
                    />
                  </div>
                  <div className="space-y-1">
                    <span className="text-[10px] font-black uppercase text-slate-400 tracking-wider block">Upper Limit (b)</span>
                    <input 
                      type="number" 
                      step="any"
                      value={integralMax} 
                      onChange={(e) => setIntegralMax(e.target.value)}
                      className="w-full bg-slate-950 border border-slate-800 rounded-lg py-2 px-3 text-xs font-mono text-slate-200"
                    />
                  </div>
                </div>

                <div className="space-y-2">
                  <div className="flex justify-between items-center text-xs">
                    <span className="text-slate-400 font-bold">Subdivisions (N):</span>
                    <span className="text-emerald-400 font-black">{intervals} Intervals</span>
                  </div>
                  <input 
                    type="range" 
                    min="2" 
                    max="80" 
                    value={intervals} 
                    onChange={(e) => setIntervals(parseInt(e.target.value))}
                    className="w-full accent-emerald-500 h-1.5 bg-slate-800 rounded-lg"
                  />
                </div>

                <div className="space-y-2">
                  <span className="text-[10px] font-black uppercase text-slate-400 tracking-wider block">Riemann Summation Rule</span>
                  <div className="grid grid-cols-2 gap-2 text-xs">
                    {['left', 'right', 'midpoint', 'trapezoid'].map(method => (
                      <button
                        key={method}
                        onClick={() => setRiemannMethod(method)}
                        className={`py-2 px-2 border rounded-xl capitalize font-bold transition-all ${
                          riemannMethod === method ? 'bg-emerald-500/15 border-emerald-500 text-emerald-400' : 'bg-slate-950 border-slate-800 text-slate-400'
                        }`}
                      >
                        {method} approximation
                      </button>
                    ))}
                  </div>
                </div>
              </div>
            )}
          </div>

          <div className="space-y-2 border-t border-slate-800 pt-4">
            <button
              onClick={handleSaveToHistory}
              disabled={errorMessage !== null}
              className="w-full bg-slate-800 hover:bg-slate-750 disabled:opacity-50 text-white font-black py-2.5 px-4 rounded-xl text-xs transition-all flex items-center justify-center gap-2"
            >
              <Bookmark className="w-4 h-4" /> Save Result to Sandbox Logs
            </button>
          </div>

        </section>

        {/* Right Side Column: Visualizer Viewport & Steps Solver (lg:col-span-7) */}
        <section className="lg:col-span-7 flex flex-col gap-6">
          
          {/* Real-time Math Plotter window */}
          <div className="bg-slate-900 border border-slate-800 rounded-2xl p-4 shadow-xl flex flex-col gap-3">
            <div className="flex items-center justify-between">
              <h3 className="text-xs font-black uppercase text-slate-400 tracking-wider flex items-center gap-2">
                <Activity className="w-4 h-4 text-emerald-400" />
                Live Function Graphing Plotter
              </h3>

              {/* Zoom settings */}
              <div className="flex gap-1 bg-slate-950 border border-slate-850 p-0.5 rounded-lg">
                <button 
                  onClick={() => setZoomLevel(prev => Math.min(prev + 0.5, 3))}
                  className="p-1 text-slate-400 hover:text-white"
                  title="Zoom Out"
                >
                  <ZoomOut className="w-3.5 h-3.5" />
                </button>
                <button 
                  onClick={() => setZoomLevel(prev => Math.max(prev - 0.25, 0.5))}
                  className="p-1 text-slate-400 hover:text-white"
                  title="Zoom In"
                >
                  <ZoomIn className="w-3.5 h-3.5" />
                </button>
                <button 
                  onClick={() => setZoomLevel(1)}
                  className="px-1.5 text-[9px] font-bold text-slate-400 hover:text-white"
                >
                  100%
                </button>
              </div>
            </div>

            <div className="w-full h-[300px]">
              {renderVisualGraph()}
            </div>
          </div>

          {/* Solution Highlight Frame */}
          <div className="bg-slate-900 border border-slate-800 rounded-2xl p-5 shadow-lg flex flex-col gap-3">
            <span className="text-xs font-bold text-emerald-400 uppercase tracking-widest">Active Output</span>
            {errorMessage ? (
              <div className="bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl p-4 text-xs font-bold leading-relaxed flex items-start gap-2">
                <XCircle className="w-4 h-4 text-red-400 shrink-0 mt-0.5" />
                <span>{errorMessage}</span>
              </div>
            ) : (
              <div className="space-y-1">
                <div className="text-[10px] font-black uppercase text-slate-500 tracking-wider">
                  {activeTab === 'limit' ? 'Calculated Limit:' : activeTab === 'derivative' ? `f${derivOrder === '1' ? "'" : "''"}(x₀) Derivative Value:` : 'Approximated Integrals Value:'}
                </div>
                <div className="text-3xl md:text-4xl font-black text-white tracking-tight font-mono">
                  {activeTab === 'limit' ? limitResult : activeTab === 'derivative' ? derivResult : integralResult}
                </div>
              </div>
            )}
          </div>

          {/* Limits numerical estimation table convergence */}
          {activeTab === 'limit' && !errorMessage && (
            <div className="grid grid-cols-2 gap-4 bg-slate-900 border border-slate-800 rounded-2xl p-4 shadow-xl">
              <div className="space-y-2">
                <span className="text-[10px] font-black uppercase text-slate-400 tracking-wider">Left-Hand limit convergence table</span>
                <div className="border border-slate-850 rounded-xl overflow-hidden text-xs">
                  <div className="grid grid-cols-2 bg-slate-950 p-2 font-black text-slate-400 border-b border-slate-850">
                    <span>x value (x &lt; a)</span>
                    <span>f(x) value</span>
                  </div>
                  {limitTable.left.map((item, i) => (
                    <div key={`left-${i}`} className="grid grid-cols-2 p-2 border-b border-slate-850 font-mono text-slate-300">
                      <span>{item.x}</span>
                      <span>{isNaN(item.y) ? 'Undefined' : item.y.toFixed(5)}</span>
                    </div>
                  ))}
                </div>
              </div>
              <div className="space-y-2">
                <span className="text-[10px] font-black uppercase text-slate-400 tracking-wider">Right-Hand limit convergence table</span>
                <div className="border border-slate-850 rounded-xl overflow-hidden text-xs">
                  <div className="grid grid-cols-2 bg-slate-950 p-2 font-black text-slate-400 border-b border-slate-850">
                    <span>x value (x &gt; a)</span>
                    <span>f(x) value</span>
                  </div>
                  {limitTable.right.map((item, i) => (
                    <div key={`right-${i}`} className="grid grid-cols-2 p-2 border-b border-slate-850 font-mono text-slate-300">
                      <span>{item.x}</span>
                      <span>{isNaN(item.y) ? 'Undefined' : item.y.toFixed(5)}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}

          {/* Step-by-Step educational breakdown */}
          {!errorMessage && calculationSteps.length > 0 && (
            <div className="bg-slate-900 border border-slate-800 rounded-2xl p-5 shadow-xl space-y-4">
              <h3 className="text-xs font-black uppercase text-slate-400 tracking-wider border-b border-slate-800 pb-2">
                Systematic Mathematical Resolutions
              </h3>
              <div className="space-y-4">
                {calculationSteps.map((step, idx) => (
                  <div key={`step-${idx}`} className="flex gap-4 relative">
                    {idx < calculationSteps.length - 1 && (
                      <div className="absolute left-3.5 top-6 bottom-[-20px] w-0.5 bg-slate-800"></div>
                    )}
                    
                    <div className="w-7 h-7 rounded-full bg-slate-950 border border-emerald-400/80 text-emerald-400 text-xs flex items-center justify-center font-black z-10 shrink-0">
                      {idx + 1}
                    </div>

                    <div className="space-y-1 pt-0.5">
                      <h4 className="text-xs font-extrabold text-white">{step.title}</h4>
                      <p className="text-[11px] text-slate-400 leading-relaxed font-sans">
                        {step.desc}
                      </p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

        </section>

      </main>

      {/* Global Quick Calculations Log Panel */}
      {history.length > 0 && (
        <div className="max-w-7xl w-full mx-auto px-4 md:px-6 mb-6">
          <div className="bg-slate-900 border border-slate-800 rounded-2xl p-4 shadow-xl">
            <div className="flex items-center justify-between mb-3 border-b border-slate-800 pb-2">
              <span className="text-xs font-black uppercase text-slate-400 tracking-wider flex items-center gap-1.5">
                <CheckCircle2 className="w-3.5 h-3.5 text-emerald-400" /> Saved Calculus Sandbox Calculations
              </span>
              <button 
                onClick={() => setHistory([])}
                className="text-[10px] text-red-400 hover:underline flex items-center gap-1 font-bold"
              >
                <Trash2 className="w-3 h-3" /> Clear Logs
              </button>
            </div>
            <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
              {history.map((item) => (
                <div 
                  key={item.id}
                  className="bg-slate-950 p-2.5 rounded-xl border border-slate-850 text-left"
                >
                  <div className="flex justify-between items-center text-[9px] font-black text-slate-500 mb-1">
                    <span className="uppercase">{item.tab}</span>
                    <span>{item.timestamp}</span>
                  </div>
                  <div className="text-[11px] font-mono text-slate-200">
                    <span className="text-emerald-400">f(x) = {item.formula}</span>
                  </div>
                  <div className="text-[10px] text-slate-400 font-bold mt-1">
                    {item.details} = <span className="text-white font-mono">{item.result}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

      {/* Global Footer */}
      <footer className="border-t border-slate-900 py-6 bg-slate-950/60 mt-auto text-center text-[10px] text-slate-500">
        <div className="max-w-7xl mx-auto px-6">
          <p>© 2026 Visual Calculus Playground & Dynamic Numerical Approximation Workspace.</p>
        </div>
      </footer>
    </div>
  );
}

